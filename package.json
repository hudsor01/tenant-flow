{
	"$schema": "https://json.schemastore.org/package",
	"name": "tenantflow",
	"private": true,
	"version": "1.0.1",
	"type": "module",
	"engines": {
		"node": "24.x",
		"pnpm": ">=9"
	},
	"packageManager": "pnpm@10.29.3",
	"imports": {
		"#app/*": "./src/app/*",
		"#components/*": "./src/components/*",
		"#contexts/*": "./src/contexts/*",
		"#design-system/*": "./src/design-system/*",
		"#lib/*": "./src/lib/*",
		"#hooks/*": "./src/hooks/*",
		"#stores/*": "./src/stores/*",
		"#types/*": "./src/types/*",
		"#providers/*": "./src/providers/*",
		"#test/*": "./src/test/*",
		"#utils/*": "./src/utils/*",
		"#shared/*": "./src/shared/*"
	},
	"scripts": {
		"dev": "next dev --turbo --port 3050",
		"build": "next build",
		"start": "next start",
		"lint": "eslint \"src/**/*.{ts,tsx}\" --cache --cache-location node_modules/.cache/eslint/ --no-error-on-unmatched-pattern --no-warn-ignored",
		"lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix --no-error-on-unmatched-pattern --no-warn-ignored",
		"typecheck": "tsc --noEmit",
		"test": "vitest --run",
		"test:all": "npm run test:unit && npm run test:e2e",
		"test:unit": "vitest --run",
		"test:rls": "jest --config tests/integration/jest.config.ts --testPathPatterns=rls --forceExit --runInBand",
		"test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
		"test:e2e:tenant": "playwright test --config tests/e2e/playwright.config.ts --project=chromium -- tenant-management/",
		"test:e2e:debug": "PWDEBUG=1 playwright test --config tests/e2e/playwright.config.ts",
		"test:ci": "CI=true vitest --run",
		"clean": "rm -rf .next",
		"db:push": "supabase db push && npm run db:types",
		"db:pull": "supabase db pull",
		"db:reset": "supabase db reset && npm run db:types",
		"db:types": "supabase gen types typescript --project-id bshjmbshupiibfiewpxb > src/shared/types/supabase.ts",
		"db:seed:smoke": "psql $DATABASE_URL -f supabase/seeds/seed-common.sql -f supabase/seeds/seed-smoke.sql",
		"db:seed:dev": "psql $DATABASE_URL -f supabase/seeds/seed-common.sql -f supabase/seeds/seed-development.sql",
		"db:seed:perf": "psql $DATABASE_URL -f supabase/seeds/seed-common.sql -f supabase/seeds/seed-performance.sql",
		"validate": "npm run db:types && npm run clean && npm run typecheck && npm run lint && npm run test:unit",
		"validate:quick": "npm run db:types && npm run typecheck && npm run lint && npm run test:unit",
		"detect:types": "./scripts/check-duplicate-types.sh",
		"test:smoke": "bash scripts/smoke-test.sh",
		"health": "bash scripts/health-check.sh",
		"changelog": "git cliff --output CHANGELOG.md",
		"scan:secrets": "gitleaks detect --source . --no-git -v",
		"scan:vulns": "trivy fs --severity HIGH,CRITICAL --scanners vuln .",
		"scan:typos": "typos --format brief",
		"prepare": "git rev-parse --is-inside-work-tree > /dev/null 2>&1 && lefthook install || true"
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		]
	},
	"pnpm": {
		"overrides": {
			"@tanstack/query-core": "5.90.20",
			"typescript": "^5.9.3",
			"path-to-regexp": "^8.3.0",
			"undici": "^7.22.0",
			"diff": "^8.0.3",
			"react-router": "^7.13.0",
			"@modelcontextprotocol/sdk": "^1.26.0",
			"cross-spawn": "^7.0.6",
			"lightningcss": "1.31.1",
			"esbuild": "^0.27.3",
			"@types/react": "19.2.14",
			"@types/react-dom": "19.2.3",
			"body-parser": ">=2.2.2",
			"tmp": ">=0.2.5",
			"qs": ">=6.15.0",
			"lodash": ">=4.17.23",
			"l5.90.20s": ">=4.17.23",
			"tar": ">=7.5.9",
			"minimatch": ">=10.2.2",
			"hono": ">=4.11.9",
			"basic-ftp": ">=5.2.0",
			"serialize-javascript": ">=7.0.4",
			"rollup": ">=4.59.0",
			"@isaacs/brace-expansion": ">=5.0.1"
		},
		"onlyBuiltDependencies": [
			"supabase"
		]
	},
