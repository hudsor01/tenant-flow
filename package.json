		"react-markdown": "^10.1.0",
		"react-resizable-panels": "^4.7.1",
		"recharts": "^3.7.0",
		"rehype-raw": "^7.0.0",
		"rehype-sanitize": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"sharp": "^0.34.5",
		"sonner": "^2.0.7",
		"stripe": "^21.0.1",
