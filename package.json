{
	"$schema": "https://json.schemastore.org/package",
	"name": "tenantflow",
	"private": true,
	"version": "1.0.1",
	"license": "SEE LICENSE IN LICENSE",
	"type": "module",
	"engines": {
		"node": "24.x",
		"pnpm": "11.x"
	},
	"packageManager": "pnpm@11.1.2",
	"imports": {
		"#proxy": "./src/proxy.ts",
		"#env": "./src/env.ts",
		"#app/*": "./src/app/*",
		"#components/*": "./src/components/*",
		"#lib/*": "./src/lib/*",
		"#hooks/*": "./src/hooks/*",
		"#stores/*": "./src/stores/*",
		"#types/*": "./src/types/*",
		"#providers/*": "./src/providers/*",
		"#test/*": "./src/test/*",
		"#config/*": "./src/config/*"
	},
	"scripts": {
		"dev": "next dev --turbo --port 3050",
		"build": "next build",
		"start": "next start",
		"lint": "eslint \"src/**/*.{ts,tsx}\" --cache --cache-location node_modules/.cache/eslint/ --no-error-on-unmatched-pattern --no-warn-ignored",
		"lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix --no-error-on-unmatched-pattern --no-warn-ignored",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:unit": "vitest --run --project unit",
		"test:component": "vitest --run --project component --passWithNoTests",
		"test:integration": "vitest --run --project integration",
		"test:rls": "vitest --run --project integration",
		"test:ci": "CI=true vitest --run",
		"clean": "rm -rf .next",
		"db:push": "supabase db push && pnpm db:types",
		"db:pull": "supabase db pull",
		"db:reset": "supabase db reset && pnpm db:types",
		"db:types": "bash scripts/db-types.sh",
		"db:seed:smoke": "psql $DATABASE_URL -f supabase/seeds/seed-common.sql -f supabase/seeds/seed-smoke.sql",
		"db:seed:dev": "psql $DATABASE_URL -f supabase/seeds/seed-common.sql -f supabase/seeds/seed-development.sql",
		"db:seed:perf": "psql $DATABASE_URL -f supabase/seeds/seed-common.sql -f supabase/seeds/seed-performance.sql",
		"validate": "pnpm clean && pnpm typecheck && pnpm lint && pnpm test:unit",
		"validate:quick": "pnpm typecheck && pnpm lint && pnpm test:unit",
		"detect:types": "./scripts/check-duplicate-types.sh",
		"health": "bash scripts/health-check.sh",
		"changelog": "git cliff --output CHANGELOG.md",
		"scan:secrets": "gitleaks detect --source . --no-git -v",
		"prepare": "git rev-parse --is-inside-work-tree > /dev/null 2>&1 && lefthook install || true"
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		]
	},
	"pnpm": {
		"overrides": {
			"typescript": "^6.0.3",
			"path-to-regexp": ">=8.4.2",
			"undici": ">=8.2.0",
			"diff": ">=9.0.0",
			"react-router": ">=7.15.1",
			"cross-spawn": ">=7.0.6",
			"lightningcss": "1.32.0",
			"esbuild": ">=0.28.0",
			"@types/react": "19.2.14",
			"@types/react-dom": "19.2.3",
			"body-parser": ">=2.2.2",
			"tmp": ">=0.2.5",
			"qs": ">=6.15.1",
			"lodash": ">=4.18.1",
			"tar": ">=7.5.15",
			"minimatch": ">=10.2.5",
			"express-rate-limit": ">=8.5.2",
			"flatted": ">=3.4.2",
			"basic-ftp": ">=6.0.1",
			"serialize-javascript": ">=7.0.5",
			"rollup": ">=4.60.3",
			"@isaacs/brace-expansion": ">=5.0.1",
			"picomatch": ">=4.0.4",
			"brace-expansion": ">=5.0.5",
			"yaml": ">=2.9.0",
			"smol-toml": ">=1.6.1",
			"uuid": ">=14.0.0",
			"postcss": ">=8.5.14",
			"ip-address": ">=10.2.0"
		},
		"peerDependencyRules": {
			"allowedVersions": {
				"eslint-plugin-react-hooks>eslint": ">=10",
				"@tanstack/eslint-plugin-query>eslint": ">=10"
			}
		},
		"onlyBuiltDependencies": [
			"@sentry/cli",
			"esbuild",
			"lefthook",
			"msw",
			"sharp",
			"supabase"
		]
	},
	"dependencies": {
		"@diceui/combobox": "1.2.2",
		"@dnd-kit/core": "6.3.1",
		"@dnd-kit/modifiers": "9.0.0",
		"@dnd-kit/sortable": "10.0.0",
		"@dnd-kit/utilities": "3.2.2",
		"@floating-ui/react-dom": "^2.1.8",
		"@number-flow/react": "0.6.0",
		"@sentry/nextjs": "^10.52.0",
		"@supabase/ssr": "^0.10.2",
		"@supabase/supabase-js": "^2.103.3",
		"@t3-oss/env-nextjs": "^0.13.11",
		"@tanstack/react-form": "^1.32.0",
		"@tanstack/react-query": "^5.100.10",
		"@tanstack/react-query-persist-client": "^5.100.9",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.13.24",
		"@vercel/analytics": "^2.0.1",
		"@vercel/og": "0.11.1",
		"@vercel/speed-insights": "^2.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"dompurify": "^3.4.1",
		"geist": "^1.7.0",
		"idb-keyval": "^6.2.2",
		"input-otp": "^1.4.2",
		"lucide-react": "^1.14.0",
		"next": "16.2.6",
		"next-themes": "^0.4.6",
		"nuqs": "^2.8.9",
		"papaparse": "^5.5.3",
		"radix-ui": "^1.4.3",
		"react": "19.2.6",
		"react-day-picker": "^10.0.0",
		"react-dom": "19.2.6",
		"react-dropzone": "^15.0.0",
		"react-error-boundary": "^6.1.1",
		"react-intersection-observer": "^10.0.3",
		"react-markdown": "^10.1.0",
		"recharts": "^3.8.1",
		"rehype-raw": "^7.0.0",
		"rehype-sanitize": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"sharp": "^0.34.5",
		"sonner": "^2.0.7",
		"stripe": "^22.1.0",
		"tailwind-merge": "^3.6.0",
		"zod": "^4.4.3",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/js": "^10.0.1",
		"@faker-js/faker": "^10.4.0",
		"@next/eslint-plugin-next": "~16.2.4",
		"@playwright/test": "1.60.0",
		"@tailwindcss/postcss": "^4.3.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tanstack/eslint-plugin-query": "^5.100.10",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.7.0",
		"@types/papaparse": "^5.5.2",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.5",
		"babel-plugin-react-compiler": "^1.0.0",
		"dotenv": "^17.4.2",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-no-barrel-files": "^1.3.1",
		"eslint-plugin-react-hooks": "^7.1.1",
		"fast-check": "^4.8.0",
		"globals": "^17.6.0",
		"jsdom": "^29.1.1",
		"knip": "^6.12.2",
		"lefthook": "^2.1.6",
		"msw": "2.14.2",
		"playwright": "1.60.0",
		"postcss": ">=8.5.14",
		"prettier": "^3.8.3",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"schema-dts": "^2.0.0",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.11",
		"vitest": "^4.1.5"
	}
}