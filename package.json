{
	"$schema": "https://json.schemastore.org/package",
	"name": "tenantflow",
	"private": true,
	"version": "1.0.1",
	"license": "SEE LICENSE IN LICENSE",
	"type": "module",
	"engines": {
		"node": "24.x",
		"bun": "1.3.x"
	},
	"packageManager": "bun@1.3.14",
	"imports": {
		"#proxy": "./src/proxy.ts",
		"#env": "./src/env.ts",
		"#app/*": "./src/app/*",
		"#components/*": "./src/components/*",
		"#lib/*": "./src/lib/*",
		"#hooks/*": "./src/hooks/*",
		"#stores/*": "./src/stores/*",
		"#types/*": "./src/types/*",
		"#providers/*": "./src/providers/*",
		"#test/*": "./src/test/*",
		"#config/*": "./src/config/*"
	},
	"scripts": {
		"dev": "next dev --turbo --port 3050",
		"build": "next build",
		"start": "next start",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:unit": "vitest --run --project unit",
		"test:component": "vitest --run --project component --passWithNoTests",
		"test:integration": "vitest --run --project integration",
		"test:rls": "vitest --run --project integration",
		"test:ci": "CI=true vitest --run",
		"test:e2e": "bunx playwright test --config tests/e2e/playwright.config.ts",
		"clean": "rm -rf .next",
		"db:push": "supabase db push && bun run db:types",
		"db:pull": "supabase db pull",
		"db:reset": "supabase db reset && bun run db:types",
		"db:types": "bash scripts/db-types.sh",
		"validate": "bun run clean && bun run typecheck && bun run lint && bun run test:unit",
		"validate:quick": "bun run typecheck && bun run lint && bun run test:unit",
		"detect:types": "./scripts/check-duplicate-types.sh",
		"health": "bash scripts/health-check.sh",
		"changelog": "git cliff --output CHANGELOG.md",
		"scan:secrets": "gitleaks detect --source . --no-git -v",
		"prepare": "git rev-parse --is-inside-work-tree > /dev/null 2>&1 && lefthook install || true"
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		]
	},
	"overrides": {
		"typescript": "^6.0.3",
		"path-to-regexp": ">=8.4.2",
		"undici": ">=7.25.0 <8",
		"diff": ">=9.0.0",
		"react-router": ">=7.15.1",
		"cross-spawn": ">=7.0.6",
		"lightningcss": "1.32.0",
		"esbuild": ">=0.28.0",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"body-parser": ">=2.2.2",
		"tmp": ">=0.2.5",
		"qs": ">=6.15.1",
		"lodash": ">=4.18.1",
		"tar": ">=7.5.15",
		"minimatch": ">=10.2.5",
		"express-rate-limit": ">=8.5.2",
		"flatted": ">=3.4.2",
		"basic-ftp": ">=6.0.1",
		"serialize-javascript": ">=7.0.5",
		"rollup": ">=4.60.4",
		"@isaacs/brace-expansion": ">=5.0.1",
		"picomatch": ">=4.0.4",
		"brace-expansion": ">=5.0.6",
		"yaml": ">=2.9.0",
		"smol-toml": ">=1.6.1",
		"uuid": ">=14.0.0",
		"postcss": ">=8.5.14",
		"ip-address": ">=10.2.0"
	},
	"trustedDependencies": [
		"@sentry/cli",
		"esbuild",
		"lefthook",
		"msw",
		"sharp",
		"supabase"
	],
	"dependencies": {
		"@diceui/combobox": "1.2.2",
		"@dnd-kit/core": "6.3.1",
		"@dnd-kit/modifiers": "9.0.0",
		"@dnd-kit/sortable": "10.0.0",
		"@dnd-kit/utilities": "3.2.2",
		"@floating-ui/react-dom": "^2.1.8",
		"@sentry/nextjs": "^10.53.1",
		"@supabase/ssr": "^0.10.3",
		"@supabase/supabase-js": "^2.105.4",
		"@t3-oss/env-nextjs": "^0.13.11",
		"@tanstack/react-form": "^1.32.0",
		"@tanstack/react-query": "^5.100.10",
		"@tanstack/react-query-persist-client": "^5.100.10",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.13.24",
		"@vercel/analytics": "^2.0.1",
		"@vercel/og": "0.11.1",
		"@vercel/speed-insights": "^2.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"dompurify": "^3.4.3",
		"geist": "^1.7.0",
		"idb-keyval": "^6.2.2",
		"input-otp": "^1.4.2",
		"jspdf": "4.2.1",
		"jspdf-autotable": "5.0.8",
		"lucide-react": "^1.16.0",
		"next": "16.2.10",
		"next-themes": "^0.4.6",
		"nuqs": "^2.8.9",
		"papaparse": "^5.5.3",
		"radix-ui": "^1.4.3",
		"react": "19.2.7",
		"react-day-picker": "^10.0.0",
		"react-dom": "19.2.7",
		"react-dropzone": "^15.0.0",
		"react-error-boundary": "^6.1.1",
		"react-intersection-observer": "^10.0.3",
		"react-markdown": "^10.1.0",
		"recharts": "^3.8.1",
		"rehype-raw": "^7.0.0",
		"rehype-sanitize": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"sharp": "^0.35.3",
		"sonner": "^2.0.7",
		"stripe": "^22.1.1",
		"tailwind-merge": "^3.6.0",
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
		"zod": "^4.4.3",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.12.1",
		"@biomejs/biome": "2.5.4",
		"@commitlint/cli": "^21.0.1",
		"@commitlint/config-conventional": "^21.0.1",
		"@faker-js/faker": "^10.4.0",
		"@playwright/test": "1.61.1",
		"@tailwindcss/postcss": "^4.3.0",
		"@tailwindcss/typography": "^0.5.19",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.8.0",
		"@types/papaparse": "^5.5.2",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitest/coverage-v8": "^4.1.6",
		"babel-plugin-react-compiler": "^1.0.0",
		"dotenv": "^17.4.2",
		"fast-check": "^4.8.0",
		"jsdom": "^29.1.1",
		"knip": "^6.13.1",
		"lefthook": "^2.1.6",
		"msw": "2.15.0",
		"playwright": "1.61.1",
		"postcss": ">=8.5.14",
		"schema-dts": "^2.0.0",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.13",
		"vitest": "^4.1.6"
	}
}
