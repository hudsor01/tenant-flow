{
	"$schema": "https://json.schemastore.org/package",
	"name": "tenantflow",
	"private": true,
	"version": "1.0.1",
	"type": "module",
	"engines": {
		"node": ">=24",
		"pnpm": "10.x"
	},
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
	"imports": {
		"#proxy": "./src/proxy.ts",
		"#env": "./src/env.ts",
		"#app/*": "./src/app/*",
		"#components/*": "./src/components/*",
		"#contexts/*": "./src/contexts/*",
		"#design-system/*": "./src/design-system/*",
		"#lib/*": "./src/lib/*",
		"#hooks/*": "./src/hooks/*",
		"#stores/*": "./src/stores/*",
		"#types/*": "./src/types/*",
		"#providers/*": "./src/providers/*",
		"#test/*": "./src/test/*",
		"#utils/*": "./src/utils/*",
		"#shared/*": "./src/shared/*",
		"#config/*": "./src/config/*"
	},
	"scripts": {
		"dev": "next dev --turbo --port 3050",
		"build": "next build",
		"start": "next start",
		"lint": "eslint \"src/**/*.{ts,tsx}\" --cache --cache-location node_modules/.cache/eslint/ --no-error-on-unmatched-pattern --no-warn-ignored",
		"lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix --no-error-on-unmatched-pattern --no-warn-ignored",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:all": "pnpm test:unit && pnpm test:e2e",
		"test:unit": "vitest --run --project unit",
		"test:component": "vitest --run --project component --passWithNoTests",
		"test:integration": "vitest --run --project integration",
		"test:rls": "vitest --run --project integration",
		"test:ci": "CI=true vitest --run",
		"clean": "rm -rf .next",
		"db:push": "supabase db push && pnpm db:types",
		"db:pull": "supabase db pull",
		"db:reset": "supabase db reset && pnpm db:types",
		"db:types": "supabase gen types typescript --project-id bshjmbshupiibfiewpxb > src/types/supabase.ts",
		"db:seed:smoke": "psql $DATABASE_URL -f supabase/seeds/seed-common.sql -f supabase/seeds/seed-smoke.sql",
		"db:seed:dev": "psql $DATABASE_URL -f supabase/seeds/seed-common.sql -f supabase/seeds/seed-development.sql",
		"db:seed:perf": "psql $DATABASE_URL -f supabase/seeds/seed-common.sql -f supabase/seeds/seed-performance.sql",
		"validate": "pnpm db:types && pnpm clean && pnpm typecheck && pnpm lint && pnpm test:unit",
		"validate:quick": "pnpm db:types && pnpm typecheck && pnpm lint && pnpm test:unit",
		"detect:types": "./scripts/check-duplicate-types.sh",
		"health": "bash scripts/health-check.sh",
		"changelog": "git cliff --output CHANGELOG.md",
		"scan:secrets": "gitleaks detect --source . --no-git -v",
		"prepare": "git rev-parse --is-inside-work-tree > /dev/null 2>&1 && lefthook install || true"
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		]
	},
	"pnpm": {
		"overrides": {
			"typescript": "^5.9.3",
			"path-to-regexp": ">=8.4.0",
			"undici": ">=7.24.0",
			"diff": ">=8.0.3",
			"react-router": ">=7.13.0",
			"@modelcontextprotocol/sdk": ">=1.26.0",
			"cross-spawn": ">=7.0.6",
			"lightningcss": "1.31.1",
			"esbuild": ">=0.27.3",
			"@types/react": "19.2.14",
			"@types/react-dom": "19.2.3",
			"body-parser": ">=2.2.2",
			"tmp": ">=0.2.5",
			"qs": ">=6.15.0",
			"lodash": ">=4.17.23",
			"tar": ">=7.5.9",
			"minimatch": ">=10.2.2",
			"hono": ">=4.12.14",
			"@hono/node-server": ">=1.19.13",
			"express-rate-limit": ">=8.2.2",
			"flatted": ">=3.4.0",
			"basic-ftp": ">=5.2.0",
			"serialize-javascript": ">=7.0.5",
			"rollup": ">=4.59.0",
			"@isaacs/brace-expansion": ">=5.0.1",
			"picomatch": ">=4.0.4",
			"brace-expansion": ">=5.0.5",
			"yaml": ">=2.8.3",
			"smol-toml": ">=1.6.1"
		},
		"peerDependencyRules": {
			"allowedVersions": {
				"eslint-plugin-react-hooks>eslint": ">=10",
				"@tanstack/eslint-plugin-query>eslint": ">=10"
			}
		},
		"onlyBuiltDependencies": [
			"supabase"
		]
	},
	"dependencies": {
		"@diceui/combobox": "1.2.2",
