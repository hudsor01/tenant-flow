. "$(dirname -- "$0")/init.sh"

# Husky v9.1.7 optimized pre-commit hook
# Comprehensive validation before commit

echo "🔍 Running pre-commit validation (db types + duplicate check + lockfile + lint + typecheck + tests)..."

# Step 1: Regenerate DB types from live schema (ensures types are always current)
# Write to a temp file first — never overwrite supabase.ts if generation fails
echo "🗄️ Regenerating DB types from Supabase..."
SUPABASE_TMP=$(mktemp)
if supabase gen types typescript --project-id bshjmbshupiibfiewpxb > "$SUPABASE_TMP" 2>/dev/null && [ -s "$SUPABASE_TMP" ]; then
  cp "$SUPABASE_TMP" packages/shared/src/types/supabase.ts
  pnpm --filter @repo/shared generate:schemas > /dev/null 2>&1 || true
  git add packages/shared/src/types/supabase.ts 2>/dev/null || true
else
  echo "⚠️ DB type regeneration failed - continuing with existing types"
fi
rm -f "$SUPABASE_TMP"

# Step 2: Check for new duplicate type definitions
echo "🔎 Checking for new duplicate type definitions..."
if ! ./scripts/check-duplicate-types.sh; then
  echo "❌ New duplicate types detected!"
  echo "Consolidate types before committing. See CLAUDE.md."
  exit 1
fi

# Step 3: Verify pnpm lockfile is in sync
echo "📦 Verifying pnpm lockfile is up to date..."
if ! pnpm install --frozen-lockfile --prefer-offline > /dev/null 2>&1; then
  echo "❌ pnpm-lock.yaml is out of sync!"
  echo "Please run 'pnpm install' and commit the lockfile changes."
  exit 1
fi

# Step 4: Turbo runs lint, typecheck, and unit tests
# Integration/e2e tests excluded (require running services)
# Run tasks for all packages to ensure comprehensive validation
# --continue: Show all errors across all packages
# --output-logs=errors-only: Only show failed task output (cleaner logs)
# --summarize: Display cache performance metrics
CI=true npx turbo run lint typecheck test:unit \
  --continue \
  --force \
  --output-logs=errors-only \
  --summarize || {
    echo "❌ Pre-commit checks failed!"
    echo "Fix errors before committing."
    exit 1
}

# Step 5: RLS integration tests against live Supabase (catches cross-tenant isolation regressions)
# Credentials loaded from root .env.local by apps/integration-tests/src/setup/env.ts
echo "🔐 Running RLS integration tests against Supabase..."
if ! pnpm --filter @repo/integration-tests test:rls; then
  echo "❌ RLS integration tests failed!"
  echo "Fix cross-tenant isolation issues before committing."
  exit 1
fi

echo "✅ All pre-commit checks passed!"