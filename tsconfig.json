{
	"$schema": "https://json.schemastore.org/tsconfig",
	"display": "TenantFlow",
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"baseUrl": ".",
		"verbatimModuleSyntax": false,
		"noEmit": true,
		"jsx": "preserve",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"composite": false,
		"declaration": false,
		"incremental": true,
		"plugins": [{ "name": "next" }],
		"types": ["next/types/global", "node", "vitest/globals"],
		"paths": {
			"#env": ["./src/env.ts"],
			"#app/*": ["./src/app/*"],
			"#components/*": ["./src/components/*"],
			"#contexts/*": ["./src/contexts/*"],
			"#design-system/*": ["./src/design-system/*"],
			"#lib/*": ["./src/lib/*"],
			"#hooks/*": ["./src/hooks/*"],
			"#stores/*": ["./src/stores/*"],
			"#types/*": ["./src/types/*"],
			"#providers/*": ["./src/providers/*"],
			"#test/*": ["./src/test/*"],
			"#config/*": ["./src/config/*"],
			"#utils/*": ["./src/utils/*"],
			"#shared/*": ["./src/shared/*"]
		}
	},
	"include": [
		"next-env.d.ts",
		"src/**/*.ts",
		"src/**/*.tsx",
		"src/**/*.d.ts",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"next.config.ts",
		"scripts/**/*.ts"
	],
	"exclude": [
		"node_modules",
		".next",
		"out",
		"dist",
		"coverage",
		"playwright-report",
		"tests/**/*",
		"src/test/**/*"
	]
}
