# ===========================================
# TenantFlow Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values
# For production, configure in Vercel dashboard
#
# Validated at build time by src/env.ts (@t3-oss/env-nextjs)

# ===========================================
# Supabase (required)
# Get from: Supabase Dashboard → Settings → API
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Service role key (server-only, bypasses RLS)
# Used for invitation auto-linking in auth callback
SUPABASE_SERVICE_ROLE_KEY=sbp_xxx

# ===========================================
# App URL (required)
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3050

# ===========================================
# Stripe (required)
# Get from: Stripe Dashboard → Developers → API Keys
# ===========================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# Stripe price IDs (required — server-side checkout)
# Get from: Stripe Dashboard → Products → Prices
STRIPE_STARTER_MONTHLY=price_xxx
STRIPE_STARTER_ANNUAL=price_xxx
STRIPE_GROWTH_MONTHLY=price_xxx
STRIPE_GROWTH_ANNUAL=price_xxx
STRIPE_MAX_MONTHLY=price_xxx
STRIPE_MAX_ANNUAL=price_xxx

# Stripe price IDs (optional — client-side plan display)
# NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_xxx
# NEXT_PUBLIC_STRIPE_PROFESSIONAL_PRICE_ID=price_xxx
# NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=price_xxx

# ===========================================
# Sentry (optional — source map uploads)
# ===========================================
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=sntrys_xxx

# ===========================================
# Testing (required for RLS and E2E tests)
# ===========================================
E2E_OWNER_EMAIL=owner-a@example.com
E2E_OWNER_PASSWORD=test-password
E2E_OWNER_B_EMAIL=owner-b@example.com
E2E_OWNER_B_PASSWORD=test-password
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ===========================================
# Edge Functions (configured in Supabase dashboard)
# Not needed in .env.local — set via `supabase secrets set`
# ===========================================
# RESEND_API_KEY=re_xxx
# DOCUSEAL_URL=https://your-docuseal.example.com
# DOCUSEAL_API_KEY=xxx
# DOCUSEAL_WEBHOOK_SECRET=xxx
# STIRLING_PDF_URL=https://your-stirling.example.com
# FRONTEND_URL=http://localhost:3050

# ===========================================
# CI/CD (GitHub Actions secrets only)
# ===========================================
# SUPABASE_ACCESS_TOKEN=sbp_xxx
# SUPABASE_PROJECT_REF=your-project-ref
