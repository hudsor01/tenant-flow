{
	"$schema": "https://json.schemastore.org/package",
	"name": "tenantflow-e2e-tests",
	"private": true,
	"version": "0.1.0",
	"description": "Playwright smoke and staging monitors for TenantFlow.",
	"type": "module",
	"scripts": {
		"preflight": "bun scripts/preflight.ts",
		"test": "bunx playwright test",
		"test:with-preflight": "bun run preflight && bun run test",
		"test:chromium": "preserve-env=PLAYWRIGHT_BASE_URL,E2E_OWNER_EMAIL,E2E_OWNER_PASSWORD,E2E_TENANT_EMAIL,E2E_TENANT_PASSWORD -- bunx playwright test --project=chromium",
		"test:public": "bunx playwright test --project=public",
		"test:mobile": "preserve-env=PLAYWRIGHT_BASE_URL,E2E_OWNER_EMAIL,E2E_OWNER_PASSWORD,E2E_TENANT_EMAIL,E2E_TENANT_PASSWORD -- bunx playwright test --project=mobile-chrome",
		"test:staging": "bunx playwright test --project=staging",
		"test:prod": "bunx playwright test --config=playwright.config.prod.ts",
		"test:performance": "preserve-env=PLAYWRIGHT_BASE_URL -- bunx playwright test tests/performance.spec.ts",
		"test:accessibility": "preserve-env=PLAYWRIGHT_BASE_URL -- bunx playwright test tests/accessibility.spec.ts",
		"test:contracts": "preserve-env=PLAYWRIGHT_BASE_URL -- bunx playwright test tests/integration/api-contracts.spec.ts",
		"lighthouse": "bunx lhci autorun",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.0",
		"@faker-js/faker": "10.2.0",
		"@lhci/cli": "0.15.1",
		"@playwright/test": "1.58.2",
		"@types/node": "^25.0.9",
		"dotenv": "17.3.1",
		"fast-check": "^4.5.3",
		"lighthouse": "13.0.1",
		"typescript": "^5.9.3"
	},
	"dependencies": {}
}
