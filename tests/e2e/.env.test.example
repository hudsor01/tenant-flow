# E2E Test Environment Configuration
# Copy to .env.test and fill in real values
#
# For local Supabase: use values from `supabase status`
# For remote Supabase: use values from Supabase Dashboard > Settings > API

# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Test Users - Owner A (primary test owner)
E2E_OWNER_EMAIL=owner-a@test.example
E2E_OWNER_PASSWORD=test-password-here

# Test Users - Owner B (cross-owner isolation tests)
E2E_OWNER_B_EMAIL=owner-b@test.example
E2E_OWNER_B_PASSWORD=test-password-here

# Test Users - Tenant (tenant portal tests)
E2E_TENANT_EMAIL=tenant@test.example
E2E_TENANT_PASSWORD=test-password-here

# App URL (for E2E, typically local dev server)
NEXT_PUBLIC_APP_URL=http://localhost:3050
